# Application
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
APP_DEBUG=false

# JWT (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY_PATH=./private.pem
JWT_PUBLIC_KEY_PATH=./public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL required)
DATABASE_URL=postgresql+asyncpg://openvpn:openvpn@db:5432/openvpn_manager

# SSH key encryption (derive from APP_SECRET_KEY, or set separately)
SSH_KEY_ENCRYPTION_SECRET=change-me-to-another-long-random-string

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Backup storage
BACKUP_STORAGE_PATH=./backups
BACKUP_MAX_RETENTION_DAYS=30

# Rate limiting (per client IP; assumes a trusted reverse proxy sets X-Forwarded-For)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=10

# Auth lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=10

# Optional Redis for shared auth state (token blacklist + login lockout).
# Required if you run more than one worker/replica; leave unset for single-worker.
# The docker-compose stack sets this automatically to the bundled redis service.
# REDIS_URL=redis://redis:6379/0

# Initial admin user (created on first startup if both are set, min 12 char password)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-at-least-12-chars
