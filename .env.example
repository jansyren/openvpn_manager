# Application
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
APP_DEBUG=false

# JWT (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY_PATH=./private.pem
JWT_PUBLIC_KEY_PATH=./public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite+aiosqlite:///./openvpn_manager.db

# SSH key encryption (derive from APP_SECRET_KEY, or set separately)
SSH_KEY_ENCRYPTION_SECRET=change-me-to-another-long-random-string

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Backup storage
BACKUP_STORAGE_PATH=./backups
BACKUP_MAX_RETENTION_DAYS=30

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=10

# Auth lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=10
